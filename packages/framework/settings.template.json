{
  "mcpServers": {
    "synapse": {
      "command": "bun",
      "args": [
        "run",
        "packages/server/src/index.ts",
        "--db",
        "SYNAPSE_DB_PATH"
      ],
      "env": {
        "OLLAMA_URL": "http://localhost:11434",
        "EMBED_MODEL": "nomic-embed-text"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node packages/framework/hooks/synapse-startup.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__synapse__store_decision",
        "hooks": [
          {
            "type": "command",
            "command": "node packages/framework/hooks/tier-gate.js"
          },
          {
            "type": "command",
            "command": "node packages/framework/hooks/precedent-gate.js"
          }
        ]
      },
      {
        "matcher": "mcp__synapse__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node packages/framework/hooks/tool-allowlist.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node packages/framework/hooks/audit-log.js"
          }
        ]
      }
    ]
  }
}
